{
    "compilerOptions": {
        "target": "es2015",
        "module": "esnext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "moduleResolution": "node",
        "sourceMap": true
    },
    "include": [
        "src/**/*"
    ]
}